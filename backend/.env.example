# Variables de entorno — Backend (Vercel + Supabase)

# URL completa de conexión (Desde Supabase)
DATABASE_URL="postgresql://usuario:contraseña@host:puerto/postgres"

# CORS: origen del frontend (ej: https://map.aquavisor.co)
CORS_ORIGIN=http://localhost:5173

# Puerto (Vercel lo maneja dinámicamente, útil para local)
PORT=3000
