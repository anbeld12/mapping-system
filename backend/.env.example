# Variables de entorno — Backend (Ejemplo)

# Base de datos PostgreSQL
DB_USER=tu_usuario
DB_HOST=localhost
DB_NAME=nombre_db
DB_PASSWORD=tu_contraseña
DB_PORT=5432

# URL completa de conexión (Alternativa útil para Supabase/Neon)
DATABASE_URL="postgresql://usuario:contraseña@host:puerto/nombre_db"

# Servidor
PORT=3000

# CORS: orígenes permitidos separados por coma (ej: http://dominio.com, http://api.dominio.com)
CORS_ORIGIN=http://localhost:5173
